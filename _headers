/*
  X-Content-Type-Options: nosniff
  Referrer-Policy: no-referrer
  Permissions-Policy: camera=(), microphone=(), geolocation=(), payment=()
  Content-Security-Policy: default-src 'self'; img-src 'self' data:; style-src 'self' 'unsafe-inline'; script-src 'self'; connect-src 'self'; font-src 'none'; object-src 'none'; base-uri 'none'; frame-ancestors 'none'
  ! Report-To
  ! NEL

/pulse_public.json
  Cache-Control: public, max-age=60, must-revalidate

/garden/ecosystem.json
  Cache-Control: public, max-age=60, must-revalidate

/assets/*
  Cache-Control: public, max-age=31536000, immutable
